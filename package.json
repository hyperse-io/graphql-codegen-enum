{
  "name": "@hyperse/graphql-codegen-enum",
  "version": "1.0.4",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typings": "./dist/index.d.ts",
  "files": [
    "dist/",
    "index.js",
    "README.md",
    "CHANGELOG.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsx ./scripts/build.ts",
    "build-release": "yarn build && rimraf ./_release && yarn pack && mkdir ./_release && tar zxvf ./package.tgz --directory ./_release && rm ./package.tgz",
    "clean": "rimraf --no-glob ./dist ./coverage ./tsconfig.tsbuildinfo",
    "lint": "eslint .",
    "test": "run-s test-unit",
    "test-unit": "vitest run",
    "typecheck": "tsc --project ./tsconfig.json --noEmit",
    "lint-staged-files": "lint-staged --allow-empty",
    "codegen": "graphql-codegen --config ./codegen.cjs",
    "g:cz": "cz",
    "g:changeset": "changeset",
    "g:version": "changeset version",
    "g:release": "yarn build-release && changeset publish",
    "prepare": "yarn husky"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@graphql-codegen/plugin-helpers": "^6.3.0",
    "@graphql-codegen/schema-ast": "^5.0.2",
    "@graphql-codegen/typescript": "^5.0.10"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.31.0",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@graphql-codegen/add": "6.0.1",
    "@graphql-codegen/cli": "6.3.1",
    "@hyperse/eslint-config-hyperse": "^1.7.1",
    "@types/node": "25.6.0",
    "@vitest/coverage-istanbul": "4.1.4",
    "commitizen": "4.3.1",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "^10.2.1",
    "graphql": "16.8.1",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "npm-run-all": "4.1.5",
    "rimraf": "6.1.3",
    "tsdown": "0.21.9",
    "tsx": "^4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.4"
  },
  "peerDependencies": {
    "graphql": "^16.13.2"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": "please-use-yarn",
    "yarn": ">=1.22.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "yarn@4.14.1",
  "typescript": {
    "definition": "typings/index.d.ts"
  }
}
